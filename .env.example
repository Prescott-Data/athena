# =============================================================================
# Athena — Environment Configuration Example
# =============================================================================
# Copy this file to .env (or .env.dev for local development) and fill in the
# values for your environment. Never commit real secrets to version control.
# =============================================================================


# --- Port & Application ---
PORT=8080
APP_ENV=local   # local | development | staging | production


# --- LLM Provider Configuration ---
# Primary provider. Supported values: gemini | azure
LLM_PROVIDER=gemini
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_NAME=gemini-3-flash-preview
EMBEDDING_MODEL_NAME=gemini-embedding-001


# --- Azure OpenAI Configuration (Legacy / Fallback) ---
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# LLM Service (Legacy Azure variables)
LLM_BASE_URL=https://your-azure-openai-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
LLM_MODEL_NAME_LEGACY=gpt-4o
LLM_API_VERSION=2025-01-01-preview

# Embedding Service (Legacy Azure variables)
EMBEDDING_BASE_URL=https://your-azure-openai-resource.openai.azure.com/openai/deployments/text-embedding-ada-002/embeddings?api-version=2023-05-15
EMBEDDING_MODEL_NAME_LEGACY=text-embedding-ada-002
EMBEDDING_DIMENSIONS=1536
EMBEDDING_API_VERSION=2023-05-15


# --- MongoDB Configuration ---
MONGO_URI="mongodb://your_mongo_user:your_mongo_password@localhost:27017/your_db?authSource=your_db"
MONGO_DB=your_db_name


# --- Redis Configuration ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
CACHE_TTL=3600
REDIS_POOL_SIZE=10
REDIS_POOL_TIMEOUT=30


# --- Milvus Vector Database Configuration ---
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_DATABASE=default


# --- ArangoDB Configuration (LTM Graph) ---
ARANGODB_URL=http://localhost:8529
ARANGODB_USER=root
ARANGODB_PASSWORD=your_arangodb_password_here
ARANGODB_DATABASE=your_arangodb_database_name


# --- STM Memory Workers ---
ENABLE_MEMORY_WORKERS=true
MEMORY_WORKER_COUNT=2


# --- STM Cache Configuration ---
STM_CACHE_KEY_PREFIX=stm_cache
STM_CACHE_MAX_TURNS=10
STM_CACHE_TTL=2
STM_TASK_TIMEOUT=300


# --- LLM Guardrails ---
LLM_RATE_LIMIT_PER_MINUTE=50
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
LLM_TIMEOUT_SECONDS=10


# --- Cosine Gate Thresholds ---
CHAIN_SIM_HIGH=0.72
CHAIN_SIM_LOW=0.52


# --- Heat Scoring Weights ---
HEAT_WEIGHT_INTRINSIC=0.8
HEAT_WEIGHT_COGNITIVE=0.2
HEAT_DECAY_TAU_HOURS=24.0
HEAT_RECALL_GROWTH=1.5


# --- MTM Configuration ---
MEMORY_OS_MTM_QUALITY_MODE=balanced   # fast | balanced | thorough
MEMORY_OS_MTM_HEAT_THRESHOLD=0.8
MEMORY_OS_MTM_MAX_SEGMENTS=50
MEMORY_OS_MTM_MERGE_THRESHOLD=0.85


# --- Development & Testing ---
NODE_ENV=development
LOG_LEVEL=info   # debug | info | warn | error
RUN_LLM_INTEGRATION_TESTS=false
TEST_TIMEOUT_SECONDS=300


# --- CORS Configuration ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000"


# --- AI Agent Configuration ---
AI_AGENT_BASE_URL=http://localhost:8080


# --- Blob Storage Configuration ---
# Supported providers: minio | s3 | gcs
BLOB_PROVIDER=minio
BLOB_ENDPOINT=localhost:9000
BLOB_BUCKET=athena-blobs
BLOB_ACCESS_KEY=your_blob_access_key_here
BLOB_SECRET_KEY=your_blob_secret_key_here
BLOB_USE_SSL=false
BLOB_REGION=us-east-1
