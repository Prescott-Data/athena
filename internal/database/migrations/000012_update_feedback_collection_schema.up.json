[
  {
    "create": "feedback"
  },
  {
    "createIndexes": "feedback",
    "indexes": [
      {
        "key": { "brief_id": 1 },
        "name": "feedback_brief_id_index"
      },
      {
        "key": { "user.user_id": 1 },
        "name": "feedback_user_id_index"
      },
      {
        "key": { "created_at": -1 },
        "name": "feedback_created_at_index"
      },
      {
        "key": { "brief_id": 1, "created_at": -1 },
        "name": "feedback_brief_time_index"
      }
    ]
  },
  {
    "collMod": "feedback",
    "validator": {
