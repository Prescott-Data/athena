          "brief_id": { "bsonType": "string" },
          "created_at": { "bsonType": "date" },
          "updated_at": { "bsonType": "date" },
          "user": {
            "bsonType": "object",
            "required": ["user_id", "name", "role"],
            "properties": {
              "user_id": { "bsonType": "string" },
              "name": { "bsonType": "string" },
              "role": { "bsonType": "string" }
            }
          },
          "comment": { "bsonType": "string" }
        }
      }
    }
  }
