[
  {
    "create": "workspaces"
  },
  {
    "createIndexes": "workspaces",
    "indexes": [
      {
        "key": { "name": 1 },
        "name": "workspace_name_index"
      },
      {
        "key": { "created_by": 1 },
        "name": "workspace_created_by_index"
      },
      {
        "key": { "created_at": -1 },
        "name": "workspace_created_at_index"
      }
    ]
  },
  {
    "collMod": "workspaces",
    "validator": {
      "$jsonSchema": {
        "bsonType": "object",
        "required": ["name", "created_by", "created_at"],
        "properties": {
          "_id": {
            "bsonType": "objectId"
          },
          "name": {
            "bsonType": "string",
            "description": "Name of the workspace"
          },
          "description": {
            "bsonType": "string",
            "description": "Description of the workspace"
          },
          "channels": {
            "bsonType": "array",
            "description": "Array of channel IDs",
            "items": {
              "bsonType": "objectId"
            }
          },
          "members": {
            "bsonType": "array",
            "description": "Array of member user IDs",
            "items": {
              "bsonType": "string"
            }
          },
          "created_by": {
            "bsonType": "string",
            "description": "User ID of workspace creator"
          },
          "created_at": {
            "bsonType": "date",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "bsonType": "date",
            "description": "Last update timestamp"
          }
        }
      }
    }
  },
  {
